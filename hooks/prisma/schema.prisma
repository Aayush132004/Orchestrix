// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"       // 1. FIXED: Added missing "-js" extension
   // 2. FIXED: Changed to match your 'client' import path
}

datasource db {
  provider = "postgresql"
      // 3. FIXED: Added missing url pointer for postgresql
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  zaps     Zap[]
}

model Zap {
  id        String    @id @default(uuid())
  userId     Int
  trigger   Trigger?
  actions   Action[]  // a zap can have multiple actions
  zapRuns   ZapRuns[]
  user      User @relation(fields:[userId],references:[id])

}

model Trigger {
  id        String            @id @default(uuid())
  triggerId String
  zapId      String @unique
  metadata   Json @default("{}")
  type      AvailableTriggers @relation(fields: [triggerId], references: [id])
  
  zap       Zap              @relation(fields:[zapId], references:[id])
}

model Action {
  id       String          @id @default(uuid())
  zapId    String 
  zap      Zap             @relation(fields: [zapId], references: [id])
  actionId String
  metadata   Json @default("{}")
  type     AvailableAction @relation(fields: [actionId], references: [id])
  sortingOrder Int @default(0)
}

model AvailableTriggers {
  id       String    @id @default(uuid())
  name     String
  image    String
  triggers Trigger[]
}

model AvailableAction {
  id      String   @id @default(uuid())
  name    String
  image   String
  actions Action[]
}

// Instances of zaps which are executed
model ZapRuns {
  id           String        @id @default(uuid())
  zapId        String
  metadata     Json
  createdAt    DateTime      @default(now())
  zapRunOutbox ZapRunOutbox? // one to one relation with zapRunOutbox
  zap          Zap           @relation(fields: [zapId], references: [id])
}

// Outbox pattern table to reliably send transactions to Kafka/RabbitMQ
model ZapRunOutbox {
  id       String  @id @default(uuid())
  zapRunId String  @unique
  zapRun   ZapRuns @relation(fields: [zapRunId], references: [id])
}